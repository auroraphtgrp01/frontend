# API Configuration
# Leave empty in dev to use same-origin `/api` via Vite proxy (recommended).
# Set explicit URL only when bypassing proxy (e.g. staging gateway).
# VITE_API_URL=http://localhost:9080
# Optional: tenant slug for requests when using plain localhost (matches identity ACADEMY_BOOTSTRAP_SLUG)
VITE_ACADEMY_SLUG=center-a

# App Info
VITE_APP_TITLE=imto Admin

# Dev-only: pre-filled login forms (vite dev). Ignored in production builds.
# Defaults are used when these are unset — see src/lib/dev-login-defaults.ts
VITE_DEV_ACADEMY_LOGIN_EMAIL=admin@center-a.local
VITE_DEV_ACADEMY_LOGIN_PASSWORD=AcademyAdmin123!
# Optional: defaults match identity ACADEMY_BOOTSTRAP_* if unset
# VITE_DEV_ACADEMY_TEACHER_EMAIL=teacher@center-a.local
# VITE_DEV_ACADEMY_TEACHER_PASSWORD=AcademyTeacher123!
# VITE_DEV_ACADEMY_USER_EMAIL=user@center-a.local
# VITE_DEV_ACADEMY_USER_PASSWORD=AcademyUser123!
VITE_DEV_SYSTEM_ADMIN_LOGIN_EMAIL=superadmin@global.local
VITE_DEV_SYSTEM_ADMIN_LOGIN_PASSWORD=SuperAdmin123!
