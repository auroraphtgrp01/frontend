{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Go Microservice API Gateway",
  "port": 9080,
  "timeout": "45s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "allow_headers": [
        "Authorization",
        "Academy",
        "Content-Type",
        "X-Request-ID",
        "Idempotency-Key",
        "Accept",
        "Origin"
      ],
      "expose_headers": ["X-Request-ID", "Content-Length"],
      "allow_credentials": true,
      "max_age": "12h"
    },
    "security/http": {
      "allowed_hosts": [],
      "ssl_redirect": false,
      "sts_seconds": 31536000,
      "sts_include_subdomains": true,
      "frame_deny": true,
      "content_type_nosniff": true,
      "browser_xss_filter": true,
      "content_security_policy": "default-src 'self'"
    },
    "telemetry/logging": {
      "level": "WARNING",
      "prefix": "[GATEWAY]",
      "syslog": false,
      "stdout": true
    }
  },
  "endpoints": [
    {{ include "health.tmpl" }},
    {{ include "identity_public.tmpl" }},
    {{ include "identity_protected.tmpl" }},
    {{ include "bff_endpoints.tmpl" }},
    {{ include "exam_endpoints.tmpl" }},
    {{ include "exam_attempt_endpoints.tmpl" }},
    {{ include "exam_runtime_endpoints.tmpl" }},
    {{ include "exam_migration_admin_endpoints.tmpl" }},
    {{ include "order_service_endpoints.tmpl" }},
    {{ include "practice_service_endpoints.tmpl" }}
  ]
}
