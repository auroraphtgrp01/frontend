{
  "@comment": "BFF: User profile — aggregated & filtered response",
  "endpoint": "/bff/v1/me",
  "method": "GET",
  "output_encoding": "json",
  "input_headers": ["Authorization", "Academy", "Content-Type", "X-Request-ID", "Accept", "Origin", "X-User-Id", "X-User-Role", "X-Academy-Id", "X-Academy-Schema"],
  "input_query_strings": ["*"],
  "extra_config": {
    "auth/validator": {
      "alg": "HS256",
      "jwk_local_path": "/etc/krakend/settings/jwt_hs256_symmetric.json",
      "operation_debug": false,
      "disable_jwk_security": true,
      "propagate_claims": [
        ["user_id", "x-user-id"],
        ["email", "x-user-email"],
        ["name", "x-user-name"],
        ["role", "x-user-role"],
        ["academy_id", "x-academy-id"],
        ["academy_slug", "academy"],
        ["academy_schema", "x-academy-schema"],
        ["sub", "x-user-sub"]
      ]
    }
  },
  "backend": [
    {
      "url_pattern": "/api/v1/users/me",
      "host": ["http://identity-service:8081"],
      "group": "profile",
      "target": "data",
      "deny": ["password", "deleted_at"],
      "extra_config": {
        "qos/circuit-breaker": {
          "interval": 60,
          "timeout": 10,
          "max_errors": 5,
          "log_status_change": true
        }
      }
    }
  ]
}
