{
  "@comment": "Start attempt",
  "endpoint": "/api/v1/attempts",
  "method": "POST",
  "output_encoding": "no-op",
  "input_headers": ["Authorization", "Academy", "X-Request-ID", "Idempotency-Key", "Content-Type", "Accept", "Origin", "X-User-Id", "X-User-Role", "X-Academy-Id", "X-Academy-Schema"],
  "extra_config": {
    "auth/validator": {
      "alg": "HS256",
      "jwk_local_path": "/etc/krakend/settings/jwt_hs256_symmetric.json",
      "disable_jwk_security": true,
      "propagate_claims": [["user_id","x-user-id"],["role","x-user-role"],["academy_id","x-academy-id"],["academy_slug","academy"],["academy_schema","x-academy-schema"]]
    },
    "qos/ratelimit/router": {
      "max_rate": 30,
      "client_max_rate": 30,
      "capacity": 30,
      "client_capacity": 30,
      "strategy": "header",
      "key": "x-user-id",
      "every": "1m"
    }
  },
  "backend": [
    {
      "url_pattern": "/api/v1/attempts",
      "host": ["http://host.docker.internal:8087"],
      "encoding": "no-op"
    }
  ]
},
