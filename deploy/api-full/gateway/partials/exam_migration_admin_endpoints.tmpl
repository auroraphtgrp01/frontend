{
  "@comment": "Exam migration jobs list — no-op pipe: Lura json merge rejects some 2xx (e.g. 202) and can return 500 invalid status code",
  "endpoint": "/api/v1/admin/exam-migrations/jobs",
  "method": "GET",
  "output_encoding": "no-op",
  "input_headers": ["Authorization", "Academy", "Content-Type", "X-Request-ID", "Idempotency-Key", "Accept", "Origin", "X-User-Id", "X-User-Role", "X-Academy-Id", "X-Academy-Schema"],
  "input_query_strings": ["mode", "status", "academy_slug", "from", "to", "limit", "cursor"],
  "extra_config": {
    "auth/validator": {
      "alg": "HS256",
      "jwk_local_path": "/etc/krakend/settings/jwt_hs256_symmetric.json",
      "operation_debug": false,
      "disable_jwk_security": true,
      "propagate_claims": [
        ["user_id", "x-user-id"],
        ["role", "x-user-role"],
        ["academy_id", "x-academy-id"],
        ["academy_slug", "academy"]
      ]
    },
    "qos/ratelimit/router": {
      "max_rate": 20,
      "client_max_rate": 20,
      "capacity": 20,
      "client_capacity": 20,
      "strategy": "header",
      "key": "x-user-id",
      "every": "1m"
    }
  },
  "backend": [
    {
      "url_pattern": "/api/v1/admin/exam-migrations/jobs",
      "host": ["http://host.docker.internal:8086"],
      "encoding": "no-op"
    }
  ]
},
