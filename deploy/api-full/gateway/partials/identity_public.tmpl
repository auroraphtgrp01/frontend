{
  "@comment": "Public auth endpoints — no JWT validation, preserve original request URL for academy resolution",
  "endpoint": "/api/v1/auth/register",
  "method": "POST",
  "output_encoding": "no-op",
  "input_headers": ["Authorization", "Academy", "Content-Type", "X-Request-ID", "Idempotency-Key", "Accept", "Origin", "X-User-Id", "X-User-Role", "X-Academy-Id", "X-Academy-Schema"],
  "input_query_strings": ["*"],
  "backend": [
    {
      "url_pattern": "/api/v1/auth/register",
      "host": ["http://identity-service:8081"],
      "encoding": "no-op",
      "extra_config": {
        "modifier/martian": {
          "stash.Modifier": {
            "scope": ["request"],
            "headerName": "X-Original-Url"
          }
        }
      }
    }
  ],
  "extra_config": {
    "qos/ratelimit/router": {
      "max_rate": 50,
      "client_max_rate": 50,
      "capacity": 50,
      "client_capacity": 50,
      "strategy": "ip",
      "every": "1m"
    }
  }
},
