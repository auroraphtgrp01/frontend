{
  "@comment": "Order Service — Orders, Appointments, Time-Slots, Scheduling, Exam-Booking, Payments, Vouchers",
  "endpoint": "/api/v1/orders",
  "method": "POST",
  "output_encoding": "no-op",
  "input_headers": ["Authorization", "Academy", "Content-Type", "X-Request-ID", "Idempotency-Key", "X-User-Id", "X-User-Role", "X-Academy-Id", "X-Academy-Schema", "Accept", "Origin"],
  "input_query_strings": ["*"],
  "extra_config": {
    "auth/validator": {
      "alg": "HS256",
      "jwk_local_path": "/etc/krakend/settings/jwt_hs256_symmetric.json",
      "disable_jwk_security": true,
      "propagate_claims": [["user_id","x-user-id"],["role","x-user-role"],["academy_id","x-academy-id"],["academy_slug","academy"],["academy_schema","x-academy-schema"]]
    },
    "qos/ratelimit/router": {
      "max_rate": 50,
      "client_max_rate": 50,
      "capacity": 50,
      "client_capacity": 50,
      "strategy": "header",
      "key": "x-user-id",
      "every": "1m"
    }
  },
  "backend": [
    {
      "url_pattern": "/api/v1/orders",
      "host": ["http://host.docker.internal:8085"],
      "encoding": "no-op"
    }
  ]
},
