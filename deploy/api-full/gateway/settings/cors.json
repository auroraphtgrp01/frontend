{
  "allow_origins": ["*"],
  "allow_methods": [
    "GET",
    "POST",
    "PUT",
    "PATCH",
    "DELETE",
    "OPTIONS"
  ],
  "allow_headers": [
    "Authorization",
    "Academy",
    "Content-Type",
    "X-Request-ID",
    "Idempotency-Key",
    "Accept",
    "Origin"
  ],
  "expose_headers": [
    "X-Request-ID",
    "Content-Length"
  ],
  "max_age": "12h",
  "allow_credentials": true
}
